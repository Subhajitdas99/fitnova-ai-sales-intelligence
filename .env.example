# ==============================================================================
# FitNova AI Sales Intelligence - Environment Configuration Template
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Application Settings
# ------------------------------------------------------------------------------
# Name of the application displayed in headers and pages.
FITNOVA_APP_NAME=FitNova AI Sales Intelligence

# Version of the current deployment.
FITNOVA_APP_VERSION=1.0.0

# Current deployment environment. Options: local, development, test, staging, production.
# In staging and production, configuration validation is strictly enforced at startup.
FITNOVA_ENVIRONMENT=development

# Enable or disable FastAPI debug mode. Set to false in production.
FITNOVA_DEBUG=false

# Root prefix for all API endpoints.
FITNOVA_API_V1_PREFIX=/api/v1

# Level of logging verbosity. Options: DEBUG, INFO, WARNING, ERROR, CRITICAL.
FITNOVA_LOG_LEVEL=INFO

# ------------------------------------------------------------------------------
# 2. Database Configuration
# ------------------------------------------------------------------------------
# Connection string for the application database. Defaults to local SQLite file.
FITNOVA_DATABASE_URL=sqlite:///./backend/fitnova_ai.db

# ------------------------------------------------------------------------------
# 3. Connection & Integration Settings
# ------------------------------------------------------------------------------
# The URL pointing to the backend FastAPI server, used by the Streamlit frontend.
FITNOVA_STREAMLIT_BACKEND_URL=http://localhost:8000

# Allowed CORS origins for the backend, separated by commas.
# FITNOVA_CORS_ORIGINS=http://localhost:8501,http://127.0.0.1:8501

# ------------------------------------------------------------------------------
# 4. Transcription & Diarization Services
# ------------------------------------------------------------------------------
# Provider to use for voice-to-text transcription. Supported: whisper.
FITNOVA_TRANSCRIPTION_PROVIDER=whisper

# Provider to use for speaker separation (diarization). Supported: whisperx, heuristic.
FITNOVA_DIARIZATION_PROVIDER=whisperx

# Whisper model size to load. Options: tiny, base, small, medium, large.
FITNOVA_WHISPER_MODEL_SIZE=base

# Device type for running Whisper models. Options: auto, cpu, cuda.
FITNOVA_WHISPER_DEVICE=auto

# Temperature parameter for Whisper transcription decoding.
FITNOVA_WHISPER_TEMPERATURE=0.0

# Device type for running WhisperX speaker diarization. Options: cpu, cuda.
FITNOVA_WHISPERX_DEVICE=cpu

# Default language code for transcription (e.g. "en", "es"). Set to "auto" to detect automatically.
FITNOVA_DEFAULT_LANGUAGE=auto

# Maximum number of retry attempts for failed transcription requests.
FITNOVA_TRANSCRIPTION_RETRY_ATTEMPTS=3

# Delay in seconds between consecutive transcription retry attempts.
FITNOVA_TRANSCRIPTION_RETRY_DELAY_SECONDS=2.0

# Optional Hugging Face token required to download WhisperX diarization models.
FITNOVA_HUGGINGFACE_AUTH_TOKEN=

# ------------------------------------------------------------------------------
# 5. LLM & Call Intelligence Services
# ------------------------------------------------------------------------------
# Provider to use for extracting insights and analysis. Supported: openrouter, openai, heuristic.
FITNOVA_ANALYSIS_PROVIDER=openrouter

# API key for OpenRouter service. Required if FITNOVA_ANALYSIS_PROVIDER is openrouter.
OPENROUTER_API_KEY=

# OpenRouter model model ID to use for inference.
OPENROUTER_MODEL=openai/gpt-4.1-mini

# API key for OpenAI service. Required if FITNOVA_ANALYSIS_PROVIDER is openai.
FITNOVA_OPENAI_API_KEY=

# OpenAI model ID to use for inference.
FITNOVA_OPENAI_MODEL=gpt-4.1-mini
